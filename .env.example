# ============== Application ==============
APP_NAME=market-oracle-agents
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============== MongoDB ==============
MONGO__URL=mongodb://localhost:27017
MONGO__DATABASE=market_scraper

# ============== Redis ==============
REDIS__URL=redis://localhost:6379/0
REDIS__CHANNEL_PREFIX=events

# ============== API Server ==============
API_HOST=0.0.0.0
API_PORT=3845

# ============== Local Accounts / Saved Binance Credentials ==============
AUTH__SESSION_COOKIE_NAME=cryptoos_session
AUTH__SESSION_COOKIE_SECURE=false
AUTH__SESSION_TTL_HOURS=24
BINANCE_ACCOUNT__ENABLED=true
# Generate with:
# uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BINANCE_CREDENTIAL_ENCRYPTION_KEY=
BINANCE_ACCOUNT__SPOT_BASE_URL=https://api.binance.com
BINANCE_ACCOUNT__FUTURES_BASE_URL=https://fapi.binance.com

# ============== Hyperliquid Settings ==============
HYPERLIQUID__ENABLED=true
HYPERLIQUID__SYMBOL=BTC
HYPERLIQUID__API_URL=https://api.hyperliquid.xyz
HYPERLIQUID__WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID__POSITION_MAX_INTERVAL=600
HYPERLIQUID__RECONNECT_MAX_ATTEMPTS=10

# ============== Processing ==============
BATCH_SIZE=100
FLUSH_INTERVAL=600

# ============== Signal System ==============
SYMBOL=BTC
