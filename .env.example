# ============== Application ==============
APP_NAME=market-oracle-agents
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============== MongoDB ==============
MONGO__URL=mongodb://localhost:27017
MONGO__DATABASE=market_scraper

# ============== Redis ==============
REDIS__URL=redis://localhost:6379/0
REDIS__CHANNEL_PREFIX=events

# ============== API Server ==============
API_HOST=0.0.0.0
API_PORT=3845

# ============== Hyperliquid Settings ==============
HYPERLIQUID__ENABLED=true
HYPERLIQUID__SYMBOL=BTC
HYPERLIQUID__API_URL=https://api.hyperliquid.xyz
HYPERLIQUID__WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID__POSITION_MAX_INTERVAL=600
HYPERLIQUID__RECONNECT_MAX_ATTEMPTS=10

# ============== Processing ==============
BATCH_SIZE=100
FLUSH_INTERVAL=5

# ============== Signal System ==============
SYMBOL=BTC

# ============== LLM Provider ==============
# OpenAI-compatible endpoint used by trading-watchlist's LLM extraction seam.
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.3-codex

# Optional: disable OpenAI Agents tracing when using a non-OpenAI endpoint.
OPENAI_AGENTS_DISABLE_TRACING=1
